{
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/*.o": true,
		"**/*.exe": true,
	},
	"C_Cpp.errorSquiggles": "disabled",
	"code-runner.runInTerminal": true,
	"code-runner.fileDirectoryAsCwd": true,
	"code-runner.ignoreSelection": true,
	"code-runner.executorMap": {
		"cpp": "powershell -NoProfile -ExecutionPolicy Bypass -File \"${workspaceRoot}\\.vscode\\run_game.ps1\""
	}
}